{
  "name": "groundwork-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "wasm": "wasm-pack build ../groundwork-sim --target web --out-dir ../groundwork-web/wasm",
    "playtest": "npx playwright test",
    "playtest:xvfb": "xvfb-run -a npx playwright test",
    "playtest:headed": "HEADED=1 npx playwright test",
    "playtest:install": "npm install --no-save @playwright/test @types/node && npx playwright install chromium",
    "screenshot": "./screenshot.sh",
    "screenshot:quick": "./screenshot.sh --quick",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "playwright-core": "^1.58.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-wasm": "^3.4.0",
    "vitest": "^4.1.0"
  }
}
