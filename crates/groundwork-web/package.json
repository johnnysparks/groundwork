{
  "name": "groundwork-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "wasm": "wasm-pack build ../groundwork-sim --target web --out-dir ../groundwork-web/wasm",
    "playtest": "npx playwright test",
    "playtest:xvfb": "xvfb-run -a npx playwright test",
    "playtest:headed": "HEADED=1 npx playwright test",
    "playtest:install": "npx playwright install chromium",
    "screenshot": "./screenshot.sh",
    "screenshot:quick": "./screenshot.sh --quick"
  },
  "dependencies": {
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.5.0",
    "@types/three": "^0.172.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-wasm": "^3.4.0"
  }
}
